local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local lp = Players.LocalPlayer

local autoKillEnabled = false

-- 1. GUI Trạng thái
local sg = Instance.new("ScreenGui", lp.PlayerGui)
sg.Name = "UltimateKillGui"
sg.ResetOnSpawn = false

local btn = Instance.new("TextButton", sg)
btn.Size = UDim2.new(0, 220, 0, 45)
btn.Position = UDim2.new(0, 10, 0.15, 0)
btn.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
btn.Text = "[G] AUTO KILL & FINISH: OFF"
btn.TextColor3 = Color3.new(1, 1, 1)
btn.Font = Enum.Font.GothamBold
btn.TextSize = 13
Instance.new("UICorner", btn)

-- 2. Hàm diệt tận gốc
local function killAndFinish()
    local folder = workspace:FindFirstChild("EnemyNpc")
    if not folder then return end
    
    local enemies = folder:GetChildren()
    for i = 1, #enemies do
        local enemy = enemies[i]
        if enemy:IsA("Model") then
            local hum = enemy:FindFirstChildOfClass("Humanoid")
            if hum then
                -- Ép máu về số âm để phá vỡ trạng thái gục
                hum.Health = -100 
                
                -- Một số game dùng thuộc tính trạng thái (State)
                -- Chúng ta ép nhân vật sang trạng thái "Dead"
                hum:ChangeState(Enum.HumanoidStateType.Dead)
            end
            
            -- Nếu nó vẫn lì lợm không biến mất, ta "xóa" nhẹ nó đi (Chỉ có tác dụng ở máy bạn)
            -- Nhưng thường ép Health âm là đủ để Server hiểu là đã chết hẳn.
        end
    end
end

-- 3. Vòng lặp quét siêu tốc
task.spawn(function()
    while true do
        if autoKillEnabled then
            pcall(killAndFinish)
        end
        task.wait(0.2) -- Quét liên tục để đảm bảo không con nào kịp gục
    end
end)

-- 4. Bật/Tắt
local function toggle()
    autoKillEnabled = not autoKillEnabled
    btn.Text = autoKillEnabled and "[G] KILL & FINISH: ACTIVE" or "[G] KILL & FINISH: OFF"
    btn.BackgroundColor3 = autoKillEnabled and Color3.fromRGB(180, 0, 0) or Color3.fromRGB(30, 0, 0)
end

UserInputService.InputBegan:Connect(function(input, chat)
    if not chat and input.KeyCode == Enum.KeyCode.G then toggle() end
end)

btn.MouseButton1Click:Connect(toggle)
