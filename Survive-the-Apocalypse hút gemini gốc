local function updatePresetList()
    for _, v in pairs(presetFrame:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    local layout = presetFrame:FindFirstChild("UIListLayout") or Instance.new("UIListLayout", presetFrame)
    
    for i, p in pairs(savedPresets) do
        local pBtn = Instance.new("TextButton", presetFrame)
        pBtn.Size = UDim2.new(1, -5, 0, 25)
        pBtn.Text = "Preset " .. i .. " (Y:" .. p.y .. ")"
        pBtn.BackgroundColor3 = Color3.fromRGB(50, 70, 50)
        pBtn.TextColor3 = Color3.new(1, 1, 1)
        pBtn.MouseButton1Click:Connect(function()
            offset = {x = p.x, y = p.y, z = p.z}
        end)
    end
end

