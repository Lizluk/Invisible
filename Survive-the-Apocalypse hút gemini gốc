-- 1. HÀM LƯU VÀ TẢI FILE (PERMANENT STORAGE)
local function saveToFile()
    local data = HttpService:JSONEncode(savedPresets)
    writefile(FILE_NAME, data)
end

local function loadFromFile()
    if isfile(FILE_NAME) then
        local data = readfile(FILE_NAME)
        savedPresets = HttpService:JSONDecode(data)
    end
end

-- Tải dữ liệu ngay khi chạy script
