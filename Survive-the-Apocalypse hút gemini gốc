-- 3. LOGIC HÚT VẬT THỂ[cite: 5]
local function applyAttraction(part)
    if not part:IsA("BasePart") or part.Anchored or capturedParts[part] then return end
    if part:IsDescendantOf(client.Character) then return end
    
    capturedParts[part] = true
    pcall(function() part.Velocity = Vector3.new(0, 0.1, 0) end) -- Đánh thức vật lý[cite: 2]

    local att = Instance.new("Attachment", part)
    local lv = Instance.new("LinearVelocity", part)
    lv.MaxForce = 1500000 
    lv.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
    lv.Attachment0 = att
    
    task.spawn(function()
        while inversionEnabled and part and part.Parent do
            local char = client.Character
            local rp = char and char:FindFirstChild("HumanoidRootPart")
            if rp then
                local targetPos = (rp.CFrame * CFrame.new(offset.x, offset.y, offset.z)).Position
                local dir = targetPos - part.Position
                lv.VectorVelocity = dir.Unit * math.clamp(dir.Magnitude * 3, 20, 150)
            end
            task.wait()
        end
        if lv then lv:Destroy() end
        if att then att:Destroy() end
        capturedParts[part] = nil
    end)
end

local function toggle()
    inversionEnabled = not inversionEnabled
    statusLabel.Text = inversionEnabled and "Status: ON (G)" or "Status: OFF (G)"
    statusLabel.TextColor3 = inversionEnabled and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    
    if inversionEnabled then
        local folder = workspace:FindFirstChild("DroppedItems")
        if folder then
            for _, v in pairs(folder:GetDescendants()) do 
                if v:IsA("BasePart") then applyAttraction(v) end 
            end
        end
    end
end

-- Lắng nghe item mới[cite: 5]
local folder = workspace:FindFirstChild("DroppedItems")
if folder then
    folder.DescendantAdded:Connect(function(v)
        if inversionEnabled and v:IsA("BasePart") then applyAttraction(v) end
    end)
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.C then toggle() end
end)
