-- CHIBAKU TENSEI: SMOOTH LANDING & STATIC HOLD
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")
local client = Players.LocalPlayer

local FILE_NAME = "MagnetStation_Data.json"
local inversionEnabled = false
local capturedParts = {}
local savedStations = {} 
local currentTargetPos = nil 

-- 1. HÀM DUY TRÌ QUYỀN KIỂM SOÁT (XỬ LÝ KHOẢNG CÁCH XA)
local function claimOwnership(part)
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(client, "SimulationRadius", 1e308)
            sethiddenproperty(client, "MaxSimulationRadius", 1e308)
        end
        part.Velocity = Vector3.new(0, 0.05, 0)
    end)
end

-- 2. HÀM LƯU/TẢI FILE
local function saveToFile()
    writefile(FILE_NAME, HttpService:JSONEncode(savedStations))
end

local function loadFromFile()
    if isfile(FILE_NAME) then
        pcall(function() savedStations = HttpService:JSONDecode(readfile(FILE_NAME)) end)
    end
end
loadFromFile()

-- 3. GIAO DIỆN (GIỮ NGUYÊN TÍNH NĂNG XÓA)
local screenGui = client:WaitForChild("PlayerGui"):FindFirstChild("MagnetUI") or Instance.new("ScreenGui", client.PlayerGui)
screenGui.Name = "MagnetUI"
screenGui.ResetOnSpawn = false

local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Size, mainFrame.Position = UDim2.new(0, 280, 0, 300), UDim2.new(0, 10, 0.5, -150)
mainFrame.BackgroundColor3, mainFrame.Draggable, mainFrame.Active = Color3.fromRGB(20, 20, 20), true, true

local label = Instance.new("TextLabel", mainFrame)
label.Size, label.Text, label.TextColor3 = UDim2.new(1, 0, 0, 40), "(G) Magnet: OFF", Color3.new(1, 0, 0)
label.BackgroundTransparency, label.TextSize = 1, 18

local scroll = Instance.new("ScrollingFrame", mainFrame)
scroll.Size, scroll.Position = UDim2.new(1, -10, 1, -100), UDim2.new(0, 5, 0, 45)
scroll.BackgroundColor3, scroll.CanvasSize = Color3.fromRGB(30, 30, 30), UDim2.new(0, 0, 10, 0)
Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 5)

local function updateUI()
    for _, v in pairs(scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    
    local fFrame = Instance.new("Frame", scroll)
    fFrame.Size, fFrame.BackgroundTransparency = UDim2.new(1, -5, 0, 35), 1
    local fBtn = Instance.new("TextButton", fFrame)
    fBtn.Size, fBtn.Text, fBtn.BackgroundColor3 = UDim2.new(1, 0, 1, 0), "Follow Me (Default)", Color3.fromRGB(45, 65, 45)
    fBtn.TextColor3 = Color3.new(1, 1, 1)
    fBtn.MouseButton1Click:Connect(function() currentTargetPos = nil end)

    for i, pos in pairs(savedStations) do
        local entry = Instance.new("Frame", scroll)
        entry.Size, entry.BackgroundTransparency = UDim2.new(1, -5, 0, 35), 1
        
        local sBtn = Instance.new("TextButton", entry)
        sBtn.Size, sBtn.Position, sBtn.Text = UDim2.new(0.8, -5, 1, 0), UDim2.new(0,0,0,0), "Station "..i
        sBtn.BackgroundColor3, sBtn.TextColor3 = Color3.fromRGB(50, 50, 50), Color3.new(1, 1, 1)
        sBtn.MouseButton1Click:Connect(function() currentTargetPos = Vector3.new(pos.x, pos.y, pos.z) end)
        
        local dBtn = Instance.new("TextButton", entry)
        dBtn.Size, dBtn.Position, dBtn.Text = UDim2.new(0.2, 0, 1, 0), UDim2.new(0.8, 0, 0, 0), "X"
        dBtn.BackgroundColor3, dBtn.TextColor3 = Color3.fromRGB(110, 35, 35), Color3.new(1, 1, 1)
        dBtn.MouseButton1Click:Connect(function() table.remove(savedStations, i) saveToFile() updateUI() end)
    end
end

local saveBtn = Instance.new("TextButton", mainFrame)
saveBtn.Size, saveBtn.Position = UDim2.new(1, -10, 0, 40), UDim2.new(0, 5, 1, -45)
saveBtn.Text, saveBtn.BackgroundColor3 = "SAVE POSITION", Color3.fromRGB(35, 35, 75)
saveBtn.TextColor3 = Color3.new(1, 1, 1)
saveBtn.MouseButton1Click:Connect(function()
    local rp = client.Character and client.Character:FindFirstChild("HumanoidRootPart")
    if rp then
        table.insert(savedStations, {x = rp.Position.X, y = rp.Position.Y, z = rp.Position.Z})
        saveToFile() updateUI()
    end
end)
updateUI()

-- 4. CƠ CHẾ HÚT MƯỢT MÀ & GIỮ CỐ ĐỊNH (ANTI-OVERSHOOT)
local function applySmoothMagnet(part)
    if not part:IsA("BasePart") or part.Anchored or capturedParts[part] then return end
    capturedParts[part] = true
    claimOwnership(part)

    -- Sử dụng AlignPosition để kiểm soát vị trí chính xác hơn LinearVelocity
    local attPart = Instance.new("Attachment", part)
    local attTarget = Instance.new("Attachment", workspace.Terrain) -- Attachment tạm trên thế giới
    
    local ap = Instance.new("AlignPosition", part)
    ap.Attachment0 = attPart
    ap.Attachment1 = attTarget
    ap.MaxForce = 10000000 
    ap.Responsiveness = 15 -- Độ nhạy (thấp hơn giúp bay mượt hơn, không bị giật)
    ap.Mode = Enum.PositionAlignmentMode.TwoAttachment
    
    task.spawn(function()
        while inversionEnabled and part and part.Parent do
            local rp = client.Character and client.Character:FindFirstChild("HumanoidRootPart")
            local finalTarget = currentTargetPos or (rp and (rp.CFrame * CFrame.new(0, 15, -5)).Position)

            if finalTarget then
                attTarget.WorldPosition = finalTarget
                local dist = (finalTarget - part.Position).Magnitude
                
                -- Tự động điều chỉnh độ mượt dựa trên khoảng cách (Phanh từ từ khi đến gần)
                if dist < 10 then
                    ap.Responsiveness = 200 -- "Khóa chặt" khi đã đến nơi
                    part.Velocity = part.Velocity * 0.5 -- Hãm lực quán tính[cite: 2]
                else
                    ap.Responsiveness = 10 -- Bay từ từ khi ở xa để không bị văng[cite: 2]
                end
                
                part.CanCollide = false
                claimOwnership(part)
            end
            RunService.Heartbeat:Wait()
        end
        if ap then ap:Destroy() end
        if attPart then attPart:Destroy() end
        if attTarget then attTarget:Destroy() end
        part.CanCollide = true
        capturedParts[part] = nil
    end)
end

-- 5. ĐIỀU KHIỂN BẬT/TẮT
local function toggle()
    inversionEnabled = not inversionEnabled
    label.Text = inversionEnabled and "(C) Magnet: ON" or "(C) Magnet: OFF"
    label.TextColor3 = inversionEnabled and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    if inversionEnabled then
        local folder = workspace:FindFirstChild("DroppedItems")
        if folder then for _, v in pairs(folder:GetDescendants()) do applySmoothMagnet(v) end end
    end
end

local folder = workspace:FindFirstChild("DroppedItems")
if folder then
    folder.DescendantAdded:Connect(function(v)
        if inversionEnabled then task.wait(0.2) applySmoothMagnet(v) end
    end)
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.C then toggle() end
end)
